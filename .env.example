HFQT_ENV_FILE=.env
HFQT_DATABASE_PATH=var/hfqt.sqlite3
HFQT_LOG_DIR=var/logs
HFQT_LOG_LEVEL=INFO
HFQT_LOG_MAX_BYTES=5242880
HFQT_LOG_BACKUP_COUNT=5
HFQT_APP_LOG_FILENAME=app.log
HFQT_TRADE_LOG_FILENAME=trades.jsonl
HFQT_ERROR_LOG_FILENAME=error.log
HFQT_OWNER_CONTROL_ENABLED=false
HFQT_REQUIRE_OWNER_TOKEN_FOR_WRITE=true
HFQT_OWNER_TOKEN=
HFQT_OWNER_SESSION_TOKEN=
HFQT_OWNER_STATE_PATH=var/owner_state.json
HFQT_TRADING_LOCKED_DEFAULT=false
HFQT_AUTH_ENABLED=false
HFQT_AUTH_MODE=off
HFQT_AUTH_PRODUCT_CODE=HFQT
HFQT_AUTH_CLIENT_VERSION=0.4.0
HFQT_AUTH_LICENSE_PATH=config/license.dat
HFQT_AUTH_TOKEN_CACHE_PATH=cache/token.cache
HFQT_AUTH_DEVICE_SECRET_PATH=config/device.secret
HFQT_AUTH_PUBLIC_KEY_PATH=config/license_public.pem
HFQT_AUTH_SERVER_BASE_URL=
HFQT_AUTH_MACHINE_BINDING_MODE=single
HFQT_AUTH_OFFLINE_GRACE_HOURS=72
HFQT_AUTH_TOKEN_REFRESH_MINUTES=720
HFQT_AUTH_HEARTBEAT_MINUTES=30
HFQT_DEFAULT_BROKER=local_paper
HFQT_DRY_RUN=false
HFQT_ALLOWED_SYMBOLS=US.IBIT,US.MSTR,US.COIN,US.MARA,US.RIOT,US.BITO,US.NVDA,US.AAPL,US.MSFT,US.AMZN,US.META,HK.00700
HFQT_WATCHLIST_TOP_N=8
HFQT_SCAN_CONCURRENCY=4
HFQT_SCAN_CACHE_TTL_SECONDS=180
HFQT_AUTO_TRADE_ENABLED=false
HFQT_AUTO_TRADE_COOLDOWN_MINUTES=15
HFQT_AUTO_TRADE_MAX_ORDERS_PER_CYCLE=1
HFQT_MAX_NOTIONAL_PER_ORDER=100000
HFQT_MAX_ORDERS_PER_DAY=20
HFQT_MIN_CONFIDENCE=0.55
HFQT_DEFAULT_QUANTITY=1
HFQT_INTRADAY_FEATURE_WINDOW_MINUTES=30
HFQT_NETWORK_INTEL_LIMIT=5
HFQT_NETWORK_INTEL_PRIMARY_AGE_HOURS=2
HFQT_NETWORK_INTEL_MAX_NEWS_AGE_HOURS=4
HFQT_NETWORK_INTEL_MAX_SOCIAL_AGE_HOURS=2
HFQT_NETWORK_INTEL_IMPORTANT_EVENT_AGE_HOURS=72
HFQT_YFINANCE_NEWS_LIMIT=4
HFQT_BTC_PROXY_SYMBOLS=US.IBIT,US.BITO,US.MSTR,US.COIN,US.MARA,US.RIOT
HFQT_X_MONITOR_ENABLED=true
HFQT_X_MONITOR_ACCOUNTS=saylor,elonmusk,BlackRock,EricBalchunas,NateGeraci,JSeyff,whale_alert
HFQT_X_MONITOR_POSTS_LIMIT=8
HFQT_WHALE_ALERT_ENABLED=true
HFQT_WHALE_ALERT_HANDLE=whale_alert
HFQT_WHALE_ALERT_MIN_BTC=500
HFQT_BTC_ETF_FLOW_ENABLED=true
HFQT_BTC_ETF_FLOW_JINA_URL=https://r.jina.ai/http://farside.co.uk/btc/
HFQT_BTC_ETF_FLOW_LOOKBACK_DAYS=5
HFQT_MACRO_EVENT_ENABLED=true
HFQT_MACRO_FED_RSS_URL=https://www.federalreserve.gov/feeds/speeches.xml
HFQT_MACRO_CPI_RELEASE_URL=https://r.jina.ai/http://www.bls.gov/news.release/cpi.nr0.htm
HFQT_MACRO_NFP_RELEASE_URL=https://r.jina.ai/http://www.bls.gov/news.release/empsit.nr0.htm
HFQT_MACRO_EVENT_LIMIT=4
HFQT_ALPHA_VANTAGE_ENABLED=true
HFQT_ALPHA_VANTAGE_API_KEY=
HFQT_ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
HFQT_ALPHA_VANTAGE_NEWS_LIMIT=3
HFQT_ALPHA_VANTAGE_TIMEOUT_SECONDS=10
HFQT_FINANCIAL_DATASETS_ENABLED=false
HFQT_FINANCIAL_DATASETS_API_KEY=
HFQT_FINANCIAL_DATASETS_BASE_URL=https://api.financialdatasets.ai
HFQT_FINANCIAL_DATASETS_MCP_URL=https://mcp.financialdatasets.ai/api
HFQT_FINANCIAL_DATASETS_STATEMENT_LIMIT=4
HFQT_HISTORY_MATCH_LIMIT=3
HFQT_HISTORY_MATCH_LOOKBACK_DAYS=30
HFQT_DYNAMIC_THRESHOLD_LOW_VOL_PCT=0.004
HFQT_DYNAMIC_THRESHOLD_HIGH_VOL_PCT=0.012
HFQT_DYNAMIC_THRESHOLD_LOW_VOL_BUMP=0.03
HFQT_DYNAMIC_THRESHOLD_HIGH_VOL_DISCOUNT=0.08
HFQT_LATENCY_BUDGET_MS=5000
HFQT_API_HOST=127.0.0.1
HFQT_API_PORT=8000

# OpenAI-compatible reasoner, for example local vLLM / Ollama compatibility layer.
# The app auto-loads `.env` on startup, then still reads values through os.getenv / os.environ.
# Ollama example:
# HFQT_LLM_BASE_URL=http://127.0.0.1:11434/v1
# HFQT_LLM_API_KEY=ollama
# HFQT_LLM_PROVIDER=ollama
# HFQT_LLM_MODEL_PRIMARY=qwen2.5:14b
HFQT_LLM_BASE_URL=
HFQT_LLM_API_KEY=
HFQT_LLM_PROVIDER=
HFQT_LLM_MODEL=
HFQT_LLM_MODE=primary
HFQT_LLM_MODEL_PRIMARY=
HFQT_LLM_MODEL_FALLBACK=
HFQT_LLM_FALLBACK_BODY_CHARS=3800
HFQT_LLM_FALLBACK_XREACH_COUNT=4
HFQT_LLM_FALLBACK_ITEM_COUNT=6
HFQT_LLM_AUTO_RETRY_WITH_FALLBACK=true
HFQT_LLM_TIMEOUT_SECONDS=15
HFQT_LLM_TEMPERATURE=0.1
HFQT_INTEL_AGENT_ENABLED=true
HFQT_INTEL_AGENT_PROVIDER=
HFQT_INTEL_AGENT_BASE_URL=
HFQT_INTEL_AGENT_API_KEY=
HFQT_INTEL_AGENT_MODEL=
HFQT_REVIEW_AGENT_ENABLED=true
HFQT_REVIEW_AGENT_PROVIDER=
HFQT_REVIEW_AGENT_BASE_URL=
HFQT_REVIEW_AGENT_API_KEY=
HFQT_REVIEW_AGENT_MODEL=
HFQT_RISK_AGENT_ENABLED=true
HFQT_RISK_AGENT_PROVIDER=
HFQT_RISK_AGENT_BASE_URL=
HFQT_RISK_AGENT_API_KEY=
HFQT_RISK_AGENT_MODEL=
HFQT_TRANSLATE_TO_ZH=false
HFQT_TRANSLATION_PROVIDER_ORDER=deepseek,glm,openai
HFQT_TRANSLATION_TIMEOUT_SECONDS=4
HFQT_TRANSLATION_MAX_TOKENS=120
HFQT_YAHOO_CHART_BASE_URL=https://query1.finance.yahoo.com
# Strongly recommended when local services are behind a system proxy:
# NO_PROXY=127.0.0.1,localhost

# Futu OpenD simulated trading
HFQT_FUTU_HOST=127.0.0.1
HFQT_FUTU_PORT=11111
HFQT_FUTU_MARKET=US
HFQT_FUTU_SECURITY_FIRM=
