# uSmart Open API example config
# Copy the required fields into your local `.env` and fill them through a secure channel.

# Environment
# Use `uat` for test integration, `prod` for real trading.
USMART_ENV=prod

# Hosts
# Official docs currently show:
# PROD trade host: https://open-jy.yxzq.com
# PROD quote host: https://open-hz.yxzq.com:8443
# PROD quote websocket: wss://open-hz.yxzq.com:8443/wss/v1
# UAT trade host: http://open-jy-uat.yxzq.com
# UAT quote host: https://open-hz-uat.yxzq.com
# UAT quote websocket: wss://open-hz-uat.yxzq.com/wss/v1
USMART_TRADE_HOST=https://open-jy.yxzq.com
USMART_QUOTE_HOST=https://open-hz.yxzq.com:8443
USMART_WS_HOST=wss://open-hz.yxzq.com:8443/wss/v1
USMART_WS_ORIGIN=https://open-hz.yxzq.com:8443
USMART_LOGIN_PATH=/user-server/open-api/login
USMART_TRADE_LOGIN_PATH=/user-server/open-api/trade-login
USMART_MARKETSTATE_PATH=/quotes-openservice/api/v1/marketstate

# Identity / auth
USMART_X_CHANNEL=
USMART_X_LANG=1
# Optional compatibility headers.
# The official trade overview examples also show X-Dt / X-Type, but per-endpoint tables are inconsistent.
USMART_X_DT=
USMART_X_TYPE=
USMART_PUBLIC_KEY=
USMART_PRIVATE_KEY=

# Login
USMART_LOGIN_TYPE=phone
USMART_AREA_CODE=
USMART_PHONE_NUMBER=
USMART_EMAIL=
USMART_LOGIN_PASSWORD=

# Trading
USMART_TRADE_PASSWORD=
USMART_ACCOUNT_TYPE=
USMART_MARKETS=
USMART_SUPPORTS_EXTENDED_HOURS=

# Network / access control
USMART_REQUIRE_IP_WHITELIST=
USMART_CLIENT_PUBLIC_IP=

# Notes
USMART_CONTACT_NOTE=
USMART_LAST_VERIFIED_AT=
