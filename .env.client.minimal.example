#
# HFQT customer-machine minimal env template
# Copy to `.env` on the customer machine, then adjust only the values you need.
# Default target:
# - local web dashboard
# - local model via Ollama/OpenAI-compatible endpoint
# - local_paper simulated broker
#
# If the customer machine needs uSmart Open API instead, use:
# `.env.client.usmart.minimal.example`
#

# -----------------------------
# App basics
# -----------------------------
HFQT_ENV_FILE=.env
HFQT_API_HOST=127.0.0.1
HFQT_API_PORT=8011
HFQT_DATABASE_PATH=var/hfqt.sqlite3
HFQT_LOG_DIR=var/logs
HFQT_LOG_LEVEL=INFO

# -----------------------------
# Broker and trading safety
# -----------------------------
# Recommended for initial customer-machine testing:
# - keep `local_paper`
# - keep auto trade off
# - turn on real broker only after joint verification
HFQT_DEFAULT_BROKER=local_paper
HFQT_DRY_RUN=false
HFQT_AUTO_TRADE_ENABLED=false
HFQT_ALLOWED_SYMBOLS=US.IBIT,US.MSTR,US.COIN,US.MARA,US.RIOT,US.BITO
HFQT_WATCHLIST_TOP_N=6
HFQT_DEFAULT_QUANTITY=1
HFQT_MAX_NOTIONAL_PER_ORDER=5000
HFQT_MAX_ORDERS_PER_DAY=10
HFQT_MIN_CONFIDENCE=0.58
HFQT_AUTO_TRADE_COOLDOWN_MINUTES=15
HFQT_AUTO_TRADE_MAX_ORDERS_PER_CYCLE=1

# -----------------------------
# Realtime scanning and data freshness
# -----------------------------
HFQT_SCAN_CONCURRENCY=4
HFQT_SCAN_CACHE_TTL_SECONDS=60
HFQT_NETWORK_INTEL_LIMIT=5
HFQT_NETWORK_INTEL_PRIMARY_AGE_HOURS=2
HFQT_NETWORK_INTEL_MAX_NEWS_AGE_HOURS=4
HFQT_NETWORK_INTEL_MAX_SOCIAL_AGE_HOURS=2
HFQT_NETWORK_INTEL_IMPORTANT_EVENT_AGE_HOURS=72
HFQT_INTRADAY_FEATURE_WINDOW_MINUTES=30
HFQT_LATENCY_BUDGET_MS=5000

# -----------------------------
# BTC-related intelligence
# -----------------------------
HFQT_BTC_PROXY_SYMBOLS=US.IBIT,US.BITO,US.MSTR,US.COIN,US.MARA,US.RIOT
HFQT_X_MONITOR_ENABLED=true
HFQT_X_MONITOR_ACCOUNTS=saylor,elonmusk,BlackRock,EricBalchunas,NateGeraci,JSeyff,whale_alert
HFQT_X_MONITOR_POSTS_LIMIT=8
HFQT_WHALE_ALERT_ENABLED=true
HFQT_WHALE_ALERT_HANDLE=whale_alert
HFQT_WHALE_ALERT_MIN_BTC=500
HFQT_BTC_ETF_FLOW_ENABLED=true
HFQT_BTC_ETF_FLOW_JINA_URL=https://r.jina.ai/http://farside.co.uk/btc/
HFQT_BTC_ETF_FLOW_LOOKBACK_DAYS=5
HFQT_MACRO_EVENT_ENABLED=true
HFQT_MACRO_FED_RSS_URL=https://www.federalreserve.gov/feeds/speeches.xml
HFQT_MACRO_CPI_RELEASE_URL=https://r.jina.ai/http://www.bls.gov/news.release/cpi.nr0.htm
HFQT_MACRO_NFP_RELEASE_URL=https://r.jina.ai/http://www.bls.gov/news.release/empsit.nr0.htm
HFQT_MACRO_EVENT_LIMIT=4

# Optional structured news enhancement.
# Leave empty if you do not have a key yet.
HFQT_ALPHA_VANTAGE_ENABLED=false
HFQT_ALPHA_VANTAGE_API_KEY=
HFQT_FINANCIAL_DATASETS_ENABLED=false
HFQT_FINANCIAL_DATASETS_API_KEY=
HFQT_FINANCIAL_DATASETS_BASE_URL=https://api.financialdatasets.ai
HFQT_FINANCIAL_DATASETS_MCP_URL=https://mcp.financialdatasets.ai/api
HFQT_FINANCIAL_DATASETS_STATEMENT_LIMIT=4

# -----------------------------
# Main analysis model
# -----------------------------
# Customer machine example: local Ollama / OpenAI-compatible endpoint
HFQT_LLM_BASE_URL=http://127.0.0.1:11434/v1
HFQT_LLM_API_KEY=ollama
HFQT_LLM_PROVIDER=ollama
HFQT_LLM_MODEL_PRIMARY=qwen2.5:14b
HFQT_LLM_MODEL_FALLBACK=
HFQT_LLM_MODE=primary
HFQT_LLM_TIMEOUT_SECONDS=20
HFQT_LLM_TEMPERATURE=0.1

# -----------------------------
# Agents
# -----------------------------
# Intel agent: use local model to summarize and denoise the raw news stream
HFQT_INTEL_AGENT_ENABLED=true
HFQT_INTEL_AGENT_PROVIDER=ollama
HFQT_INTEL_AGENT_BASE_URL=http://127.0.0.1:11434/v1
HFQT_INTEL_AGENT_API_KEY=ollama
HFQT_INTEL_AGENT_MODEL=qwen2.5:14b

# Analysis agent: decide buy / sell / hold, quantity, and limit_price
HFQT_REVIEW_AGENT_ENABLED=true
HFQT_REVIEW_AGENT_PROVIDER=ollama
HFQT_REVIEW_AGENT_BASE_URL=http://127.0.0.1:11434/v1
HFQT_REVIEW_AGENT_API_KEY=ollama
HFQT_REVIEW_AGENT_MODEL=qwen2.5:14b

# Risk agent: model-based risk review, still combined with hard-rule risk checks
HFQT_RISK_AGENT_ENABLED=true
HFQT_RISK_AGENT_PROVIDER=ollama
HFQT_RISK_AGENT_BASE_URL=http://127.0.0.1:11434/v1
HFQT_RISK_AGENT_API_KEY=ollama
HFQT_RISK_AGENT_MODEL=qwen2.5:14b

# -----------------------------
# UI and translation
# -----------------------------
HFQT_TRANSLATE_TO_ZH=false
NO_PROXY=127.0.0.1,localhost

# -----------------------------
# Owner control
# -----------------------------
# Optional but strongly recommended on customer machines.
HFQT_OWNER_CONTROL_ENABLED=true
HFQT_REQUIRE_OWNER_TOKEN_FOR_WRITE=true
HFQT_OWNER_TOKEN=
HFQT_OWNER_SESSION_TOKEN=

# -----------------------------
# Optional: Futu simulated trading
# -----------------------------
# Uncomment if the customer machine already has OpenD running.
# HFQT_DEFAULT_BROKER=futu_sim
# HFQT_FUTU_HOST=127.0.0.1
# HFQT_FUTU_PORT=11111
# HFQT_FUTU_MARKET=US
# HFQT_FUTU_SECURITY_FIRM=
