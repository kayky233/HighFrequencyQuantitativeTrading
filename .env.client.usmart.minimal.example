#
# HFQT customer-machine minimal env template for uSmart Open API
#
# Important:
# - Official public docs currently expose PROD and UAT/test environments.
# - I did not find an official "paper trading / simulated account" API in the public docs.
# - For customer-machine joint testing, treat `USMART_ENV=uat` as the test integration mode.
# - Current HFQT code supports config loading and healthcheck for uSmart.
#   The broker adapter is still scaffold-only for actual order submission.
#

# -----------------------------
# App basics
# -----------------------------
HFQT_ENV_FILE=.env
HFQT_API_HOST=127.0.0.1
HFQT_API_PORT=8011
HFQT_DATABASE_PATH=var/hfqt.sqlite3
HFQT_LOG_DIR=var/logs
HFQT_LOG_LEVEL=INFO

# -----------------------------
# Broker selection
# -----------------------------
HFQT_DEFAULT_BROKER=usmart
HFQT_DRY_RUN=false
HFQT_AUTO_TRADE_ENABLED=false
HFQT_ALLOWED_SYMBOLS=US.IBIT,US.MSTR,US.COIN,US.MARA,US.RIOT,US.BITO
HFQT_WATCHLIST_TOP_N=6
HFQT_DEFAULT_QUANTITY=1
HFQT_MAX_NOTIONAL_PER_ORDER=5000
HFQT_MAX_ORDERS_PER_DAY=10
HFQT_MIN_CONFIDENCE=0.58
HFQT_SCAN_CONCURRENCY=4
HFQT_SCAN_CACHE_TTL_SECONDS=60
HFQT_NETWORK_INTEL_LIMIT=5
HFQT_NETWORK_INTEL_PRIMARY_AGE_HOURS=2
HFQT_NETWORK_INTEL_MAX_NEWS_AGE_HOURS=4
HFQT_NETWORK_INTEL_MAX_SOCIAL_AGE_HOURS=2
HFQT_NETWORK_INTEL_IMPORTANT_EVENT_AGE_HOURS=72
HFQT_INTRADAY_FEATURE_WINDOW_MINUTES=30
HFQT_LATENCY_BUDGET_MS=5000

# -----------------------------
# Main analysis model
# -----------------------------
HFQT_LLM_BASE_URL=http://127.0.0.1:11434/v1
HFQT_LLM_API_KEY=ollama
HFQT_LLM_PROVIDER=ollama
HFQT_LLM_MODEL_PRIMARY=qwen2.5:14b
HFQT_LLM_MODE=primary

HFQT_INTEL_AGENT_ENABLED=true
HFQT_INTEL_AGENT_PROVIDER=ollama
HFQT_INTEL_AGENT_BASE_URL=http://127.0.0.1:11434/v1
HFQT_INTEL_AGENT_API_KEY=ollama
HFQT_INTEL_AGENT_MODEL=qwen2.5:14b

HFQT_REVIEW_AGENT_ENABLED=true
HFQT_REVIEW_AGENT_PROVIDER=ollama
HFQT_REVIEW_AGENT_BASE_URL=http://127.0.0.1:11434/v1
HFQT_REVIEW_AGENT_API_KEY=ollama
HFQT_REVIEW_AGENT_MODEL=qwen2.5:14b

HFQT_RISK_AGENT_ENABLED=true
HFQT_RISK_AGENT_PROVIDER=ollama
HFQT_RISK_AGENT_BASE_URL=http://127.0.0.1:11434/v1
HFQT_RISK_AGENT_API_KEY=ollama
HFQT_RISK_AGENT_MODEL=qwen2.5:14b

HFQT_TRANSLATE_TO_ZH=false
NO_PROXY=127.0.0.1,localhost

# -----------------------------
# Owner control
# -----------------------------
HFQT_OWNER_CONTROL_ENABLED=true
HFQT_REQUIRE_OWNER_TOKEN_FOR_WRITE=true
HFQT_OWNER_TOKEN=
HFQT_OWNER_SESSION_TOKEN=

# -----------------------------
# uSmart UAT / test integration
# -----------------------------
# Use this section for initial broker connectivity tests.
USMART_ENV=uat
USMART_TRADE_HOST=http://open-jy-uat.yxzq.com
USMART_QUOTE_HOST=https://open-hz-uat.yxzq.com
USMART_WS_HOST=wss://open-hz-uat.yxzq.com/wss/v1
USMART_WS_ORIGIN=https://open-hz-uat.yxzq.com
USMART_LOGIN_PATH=/user-server/open-api/login
USMART_TRADE_LOGIN_PATH=/user-server/open-api/trade-login
USMART_MARKETSTATE_PATH=/quotes-openservice/api/v1/marketstate

USMART_X_CHANNEL=
USMART_X_LANG=1
USMART_X_DT=t4
USMART_X_TYPE=
USMART_PUBLIC_KEY=
USMART_PRIVATE_KEY=

USMART_LOGIN_TYPE=phone
USMART_AREA_CODE=
USMART_PHONE_NUMBER=
USMART_EMAIL=
USMART_LOGIN_PASSWORD=
USMART_TRADE_PASSWORD=

# -----------------------------
# uSmart PROD / real trading
# -----------------------------
# When you switch to production, replace the four host values above with:
#
# USMART_ENV=prod
# USMART_TRADE_HOST=https://open-jy.yxzq.com
# USMART_QUOTE_HOST=https://open-hz.yxzq.com:8443
# USMART_WS_HOST=wss://open-hz.yxzq.com:8443/wss/v1
# USMART_WS_ORIGIN=https://open-hz.yxzq.com:8443
#
# Keep the same login paths and credential fields below.

# -----------------------------
# Optional bookkeeping
# -----------------------------
USMART_ACCOUNT_TYPE=
USMART_MARKETS=
USMART_SUPPORTS_EXTENDED_HOURS=
USMART_REQUIRE_IP_WHITELIST=
USMART_CLIENT_PUBLIC_IP=
USMART_CONTACT_NOTE=
USMART_LAST_VERIFIED_AT=

